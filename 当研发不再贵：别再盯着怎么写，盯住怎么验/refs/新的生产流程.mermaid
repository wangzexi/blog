graph LR
    A["人类评审 目标&验收标准"] --> B1
    A --> B2
    A --> B3

    B1[方案 1] -- 开发 --> C1[自动测试]
    B2[方案 2] -- 开发 --> C2[自动测试]
    B3[方案 3] -- 开发 --> C3[自动测试]

    C1 -- 问题 --> B1
    C2 -- 问题 --> B2
    C3 -- 问题 --> B3

    C1 -- 通过验收标准 --> D[人类筛选 最优方案]
    C2 -- 通过验收标准 --> D

    C3 -- 成本耗尽不能通过验收标准 --> X[放弃]

    D --> E[上线]

    %% AI参与节点：虚线框
    classDef ai stroke-dasharray: 5 5,stroke:#333;
    class B1,B2,B3,C1,C2,C3 ai;